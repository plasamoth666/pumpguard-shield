# PumpGuard Shield - Environment Configuration
# Copy this file to .env.local and add your own RPC URL

# Solana RPC Endpoint (Required)
# Get a free key from Helius: https://helius.xyz
# Or QuickNode: https://quicknode.com
CUSTOM_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY_HERE

# Optional: Fallback RPC (if primary fails)
FALLBACK_RPC_URL=https://api.mainnet-beta.solana.com

# Rate Limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=30
